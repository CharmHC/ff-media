<Page x:Class="FFMedia.Tools.VideoMerger.Views.MergerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      AllowDrop="True"
      DragOver="OnDragOverPage"
      Drop="OnFilesDropped"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <!-- The Foreground above is load-bearing (SDD §13): WPF's Frame isolates property-value
         inheritance, so the window's foreground never reaches page content and every plain TextBlock
         here would fall back to WPF's default BLACK — invisible in dark mode. -->
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <!-- No ScrollViewer here, deliberately — and no other page in the app has one either. WPF-UI's
         NavigationViewContentPresenter already wraps every page in one. A second, nested ScrollViewer
         is handed unbounded height by the outer one, so it can never scroll (ScrollableHeight = 0) —
         yet WPF's ScrollViewer marks mouse-wheel events HANDLED even when it cannot move. It therefore
         swallows every wheel tick and the shell's scroller, which does have room to scroll, never sees
         them: the page looked frozen everywhere except inside the clip list. -->
    <!-- IsSharedSizeScope: the clip-list header and every row are separate Grids, and Auto columns in
         separate Grids size INDEPENDENTLY. The shared scope makes the columns carrying a matching
         SharedSizeGroup negotiate one width, so the header cannot drift out of alignment with the rows. -->
    <StackPanel Margin="24" MaxWidth="900" HorizontalAlignment="Left" Grid.IsSharedSizeScope="True">

            <TextBlock Text="Video Merger" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Add clips, put them in order, and join them into one video."
                       Opacity="0.8" Margin="0,4,0,16" />

            <!-- 1. Clips -->
            <TextBlock Text="Clips" FontSize="16" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                <ui:Button Content="Add clips…" Icon="{ui:SymbolIcon Add24}" Click="OnPickClips" />
                <TextBlock Text="…or drop video files anywhere on this page. Drag a row to reorder it."
                           VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.7" />
            </StackPanel>

            <!-- Column headers. Grid.IsSharedSizeScope (on the page's root StackPanel) is what makes
                 these line up with the rows: two separate Grids with Auto columns size INDEPENDENTLY,
                 so without a shared scope the header would drift out of alignment as file names change.
                 Each Auto column here and in the row template below carries the same SharedSizeGroup,
                 so they negotiate one width. -->
            <Grid Margin="12,0,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="PinColumn" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StatusColumn" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="ActionsColumn" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Pin" FontSize="12" FontWeight="SemiBold" Opacity="0.7"
                           Margin="0,0,12,0"
                           ToolTip="Pinned clips keep their position when you Shuffle. Every clip is merged, pinned or not." />
                <TextBlock Grid.Column="1" Text="Clip" FontSize="12" FontWeight="SemiBold" Opacity="0.7" />
                <TextBlock Grid.Column="2" Text="Status" FontSize="12" FontWeight="SemiBold" Opacity="0.7"
                           Margin="8,0" HorizontalAlignment="Center"
                           ToolTip="Whether the clip already matches the output target, or must be re-encoded to match it." />
                <TextBlock Grid.Column="3" Text="Actions" FontSize="12" FontWeight="SemiBold" Opacity="0.7"
                           HorizontalAlignment="Center" />
            </Grid>

            <!-- ui:ListView, NOT the plain WPF ListView: WPF-UI's ControlsDictionary keys its implicit
                 styles to its OWN subclasses (Wpf.Ui.Controls.ListView / ListViewItem) and ships no
                 style for System.Windows.Controls.ListView at all — so a plain ListView keeps WPF's
                 built-in LIGHT chrome and renders as a white box on a dark page. Same family as the
                 black page text in SDD §13. ui:ListViewItem derives from the WPF one, so the
                 drag-to-reorder code-behind's `is ListViewItem` container check still holds. -->
            <ui:ListView x:Name="ClipList" ItemsSource="{Binding Clips}" MinHeight="120" MaxHeight="340"
                         Margin="0,0,0,12" AllowDrop="True"
                         Padding="4"
                         Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                         BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                         BorderThickness="1"
                         PreviewMouseLeftButtonDown="OnClipMouseDown"
                         MouseMove="OnClipMouseMove"
                         DragOver="OnClipDragOver"
                         Drop="OnClipDropped">
                <ui:ListView.ItemContainerStyle>
                    <!-- BasedOn keeps WPF-UI's themed row template; a TargetType-only Style would
                         silently fall back to WPF's default light one. -->
                    <Style TargetType="{x:Type ui:ListViewItem}" BasedOn="{StaticResource {x:Type ui:ListViewItem}}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ui:ListView.ItemContainerStyle>
                <ui:ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PinColumn" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="StatusColumn" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="ActionsColumn" />
                            </Grid.ColumnDefinitions>

                            <!-- A PIN, not a checkbox. A checkbox in a list means "include this row" in
                                 every UI the user has ever met — and they read it that way here, thinking
                                 it chose which clips to merge. It never did: it only exempts the row from
                                 Shuffle. Every clip in the list is merged, pinned or not. -->
                            <ToggleButton Grid.Column="0" IsChecked="{Binding IsLocked}"
                                          VerticalAlignment="Center" Margin="0,0,12,0"
                                          Padding="6" Background="Transparent" BorderThickness="0"
                                          ToolTip="{Binding PinTooltip}">
                                <ui:SymbolIcon x:Name="PinIcon" Symbol="PinOff24" FontSize="16" Opacity="0.5" />
                            </ToggleButton>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Details}" Opacity="0.7" FontSize="12" />
                                <ProgressBar Value="{Binding Percent, Mode=OneWay}" Maximum="100" Height="4"
                                             Margin="0,4,0,0"
                                             Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="{Binding ProgressText}" Opacity="0.6" FontSize="12"
                                           Margin="0,2,0,0" />
                            </StackPanel>

                            <Border Grid.Column="2" Padding="8,2" CornerRadius="4" Margin="8,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                <TextBlock Text="{Binding Badge}" ToolTip="{Binding BadgeTooltip}" FontSize="12" />
                            </Border>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:Button Icon="{ui:SymbolIcon ChevronUp24}" ToolTip="Move up" Margin="0,0,4,0"
                                           Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}" />
                                <ui:Button Icon="{ui:SymbolIcon ChevronDown24}" ToolTip="Move down" Margin="0,0,4,0"
                                           Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}" />
                                <ui:Button Icon="{ui:SymbolIcon Delete24}" ToolTip="Remove"
                                           Command="{Binding DataContext.RemoveClipCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}" />
                            </StackPanel>
                        </Grid>

                        <!-- Swap the pin glyph on the named element rather than through a Style: a Style
                             with a TargetType and no BasedOn silently discards WPF-UI's implicit one, and
                             a BasedOn pointing at a key WPF-UI does not register throws XamlParseException
                             at page LOAD — both have already shipped from this very page (SDD §13). -->
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                <Setter TargetName="PinIcon" Property="Symbol" Value="Pin24" />
                                <Setter TargetName="PinIcon" Property="Opacity" Value="1" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ui:ListView.ItemTemplate>
            </ui:ListView>

            <!-- 2. Order -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <ui:Button Content="Shuffle" Icon="{ui:SymbolIcon ArrowShuffle24}"
                           ToolTip="Randomize the order, leaving pinned clips in place"
                           Command="{Binding ShuffleCommand}" />
                <ui:Button Content="Clear all" Icon="{ui:SymbolIcon Dismiss24}" Margin="8,0,0,0"
                           ToolTip="Remove every clip from the list"
                           Command="{Binding ClearClipsCommand}" />
            </StackPanel>

            <!-- 3. Output -->
            <StackPanel>
                <!-- The TARGET fields only. Gated on CanEditTarget = HasClips && !IsMerging:
                     · no clips  → there is no source to bound any of these ComboBoxes against;
                     · merging   → the merge runs against a SNAPSHOT taken when Merge was clicked, so a
                       target the user can still edit describes a merge that is not the one running.
                       Flipping Container to MKV mid-merge would rewrite OutputFileName to merged.mkv
                       while the encode still writes merged.mp4 — and the history row would then name a
                       file that does not exist. Same reasoning as CanEditClips, one level up.
                     File name / Folder / Browse deliberately sit OUTSIDE this gate: picking where a
                     merge will land is meaningful before any clip has been added. -->
                <StackPanel IsEnabled="{Binding CanEditTarget}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Output" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Text="(you have overridden the derived target)" Opacity="0.7" FontSize="12"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Visibility="{Binding IsTargetOverridden, Converter={StaticResource BoolToVisibility}}" />
                        <ui:Button Content="Reset to derived" Icon="{ui:SymbolIcon ArrowReset24}" Margin="8,0,0,0"
                                   Command="{Binding ResetTargetToDerivedCommand}"
                                   Visibility="{Binding IsTargetOverridden, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>

                <UniformGrid Columns="4" Margin="0,0,0,8">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Resolution" />
                        <ComboBox ItemsSource="{Binding Bounds.Resolutions}"
                                  SelectedItem="{Binding SelectedResolution}"
                                  ToolTip="Only resolutions your clips can actually fill — upscaling adds no detail" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Frame rate" />
                        <ComboBox ItemsSource="{Binding BoundedFrameRates}" SelectedItem="{Binding SelectedFrameRate}"
                                  DisplayMemberPath="Label"
                                  ToolTip="Only rates your clips can actually supply — a higher rate would just duplicate frames" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Container" />
                        <ComboBox ItemsSource="{Binding Containers}" SelectedItem="{Binding SelectedContainer}"
                                  ToolTip="Also sets the output file's extension — ffmpeg picks its muxer from that" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="4" Margin="0,0,0,8">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Video codec" />
                        <ComboBox ItemsSource="{Binding VideoCodecs}" SelectedItem="{Binding SelectedVideoCodec}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="CRF (quality, 0–51)" />
                        <ui:TextBox Text="{Binding TargetCrf, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Audio codec" />
                        <ComboBox ItemsSource="{Binding AudioCodecs}" SelectedItem="{Binding SelectedAudioCodec}" />
                        <TextBlock Text="MP4 + Opus plays in VLC and Chrome, but not QuickTime or most TVs. MKV or AAC is safer."
                                   Visibility="{Binding ShowOpusInMp4Warning, Converter={StaticResource BoolToVisibility}}"
                                   Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                   TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Fit mode" />
                        <ComboBox ItemsSource="{Binding FitModes}" SelectedItem="{Binding SelectedFitMode}"
                                  ToolTip="How a clip whose aspect differs from the target is fitted into it" />
                    </StackPanel>
                </UniformGrid>

                <UniformGrid Columns="4" Margin="0,0,0,8">
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Audio sample rate" />
                        <!-- Bound to the NULLABLE projection, like SelectedResolution/SelectedFrameRate:
                             a ComboBox pushes null at SelectedItem while its ItemsSource is rebuilt. -->
                        <ComboBox ItemsSource="{Binding Bounds.SampleRates}"
                                  SelectedItem="{Binding SelectedAudioSampleRate}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,8">
                        <TextBlock Text="Audio channels" />
                        <ComboBox ItemsSource="{Binding Bounds.ChannelCounts}"
                                  SelectedItem="{Binding SelectedAudioChannels}" />
                    </StackPanel>
                </UniformGrid>
                </StackPanel>

                <TextBlock Text="File name" />
                <ui:TextBox Text="{Binding OutputFileName, UpdateSourceTrigger=LostFocus}" Margin="0,0,0,8" />

                <TextBlock Text="Folder" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" Text="{Binding OutputFolder, UpdateSourceTrigger=LostFocus}" />
                    <ui:Button Grid.Column="1" Content="Browse…" Icon="{ui:SymbolIcon FolderOpen24}"
                               Margin="8,0,0,0" Click="OnPickFolder" />
                </Grid>
            </StackPanel>

            <!-- 4. Summary -->
            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" Margin="0,0,0,12" TextWrapping="Wrap" />

            <!-- 5. Actions -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ui:Button Content="Merge" Appearance="Primary" Icon="{ui:SymbolIcon VideoClipMultiple24}"
                           Command="{Binding MergeCommand}" Margin="0,0,8,0" />
                <ui:Button Content="Cancel" Command="{Binding CancelCommand}" />
            </StackPanel>
            <ProgressBar Value="{Binding OverallPercent, Mode=OneWay}" Maximum="100" Height="6" />
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.8" Margin="0,6,0,0" TextWrapping="Wrap" />

    </StackPanel>
</Page>
